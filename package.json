{
  "name": "onepieceofdata-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "One Piece data exploration app built with React",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "prepare": "husky",
    "update-chart-index": "tsx src/scripts/updateEmbedChartIndex.ts",
    "wordcloud": "tsx src/scripts/generateWordCloud.ts",
    "race": "tsx src/scripts/generateAppearanceRace.ts"
  },
  "keywords": [
    "one-piece",
    "react",
    "data-visualization"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@headlessui/react": "^2.2.9",
    "@radix-ui/react-slider": "^1.3.6",
    "@supabase/supabase-js": "^2.81.0",
    "@tanstack/react-query": "^5.90.7",
    "@tanstack/react-table": "^8.21.3",
    "d3-cloud": "^1.2.9",
    "gifenc": "^1.0.3",
    "html-to-image": "^1.11.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.4.1",
    "vis-network": "^10.0.2"
  },
  "lint-staged": {
    "src/pages/OnePieceInsightsPage.tsx": [
      "tsx src/scripts/updateEmbedChartIndex.ts",
      "git add src/pages/EmbedInsightPage.tsx"
    ],
    "src/pages/EmbedInsightPage.tsx": [
      "tsx src/scripts/updateEmbedChartIndex.ts",
      "git add src/pages/EmbedInsightPage.tsx"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.1",
    "@napi-rs/canvas": "^0.1.97",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-cloud": "^1.2.9",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.9.15",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
